# ===========================================================================
# Hawkeye-Sterling  --  Environment Variables
# Copy to .env and fill in values before running.
# ===========================================================================

# --- API & Server ----------------------------------------------------------
PORT=3000
CORS_ORIGIN=*
RATE_LIMIT_RPM=100
NODE_ENV=production

# --- Authentication --------------------------------------------------------
# API key for admin endpoints. Generated on first run if left blank.
# HAWKEYE_ADMIN_KEY=

# --- Screening Thresholds --------------------------------------------------
HAWKEYE_SCREENING_DIR=.screening
HAWKEYE_T_REJECT=0.62
HAWKEYE_T_LOW=0.72
HAWKEYE_T_MEDIUM=0.82
HAWKEYE_T_HIGH=0.92

# Maximum age (hours) before sanctions lists are considered stale.
# Screening is rejected when lists exceed this threshold.
HAWKEYE_MAX_LIST_AGE_HOURS=24

# --- Integrations (required for automation scripts) ------------------------
# ANTHROPIC_API_KEY=
# ASANA_TOKEN=
# ASANA_WORKSPACE_ID=
# ASANA_TEAM_ID=
# SLACK_WEBHOOK_URL=

# --- List Refresh Schedule (cron expression for hawkeye-refresh) -----------
# REFRESH_SCHEDULE=0 */6 * * *

# --- Alert Channels -------------------------------------------------------
# Comma-separated: slack, email, sms
# ALERT_CHANNELS=slack
# ALERT_EMAIL=
# EMAIL_WEBHOOK_URL=
# SMS_WEBHOOK_URL=

# --- Optional Services -----------------------------------------------------
# EU Financial Sanctions Files bearer token
# EU_FSF_TOKEN=

# GDELT / WorldMonitor adverse-media endpoint
# WORLDMONITOR_URL=

# --- Entity & MLRO Identity -----------------------------------------------
# MLRO_NAME=
# ENTITY_LEGAL_NAME=
