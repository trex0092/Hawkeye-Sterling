# Hawkeye Sterling — environment template. Copy to .env and fill in.
# Nothing here is used by the static front-end.
# Reserved for Phase 2+ ingestion and integrations.

# Sanctions list endpoints (Phase 2)
UN_CONSOLIDATED_URL=https://scsanctions.un.org/resources/xml/en/consolidated.xml
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
OFAC_CONS_URL=https://www.treasury.gov/ofac/downloads/consolidated/cons_prim.xml
EU_FSF_URL=https://webgate.ec.europa.eu/fsd/fsf/public/files/xmlFullSanctionsList_1_1/content
UK_OFSI_URL=https://ofsistorage.blob.core.windows.net/publishlive/2022format/ConList.xml
UAE_EOCN_URL=
OPENSANCTIONS_API_KEY=

# Adverse-media providers (Phase 6)
NEWSAPI_KEY=
GDELT_API_KEY=
GOOGLE_CSE_ID=
GOOGLE_CSE_KEY=

# Cognitive engine (Phase 7 — for LLM-backed faculties / Claude Managed Agents)
ANTHROPIC_API_KEY=

# Asana delivery (Module 01 → Inbox → MLRO triage)
ASANA_PERSONAL_ACCESS_TOKEN=
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=
ASANA_SECTION_GID_FIRST_SCREENING=
ASANA_SECTION_GID_DAILY_MONITORING=
