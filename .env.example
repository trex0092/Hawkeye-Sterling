# Hawkeye Sterling — environment template. Copy to .env and fill in.
# Every variable here is read via process.env at runtime. In production
# set them in Netlify: Site settings → Environment variables.

# ─────────────────────────────────────────────────────────────────────────
# REQUIRED — core platform (nothing below will work without these)
# ─────────────────────────────────────────────────────────────────────────

# Anthropic Claude — powers the LLM-backed faculties (brain-reason server,
# super-brain narrative, MLRO auto-dispositioner).
ANTHROPIC_API_KEY=

# Asana Personal Access Token. The same token authorises every Asana
# integration (screening inbox, STR/SAR, transaction monitor, escalations).
ASANA_TOKEN=

# Asana workspace — identical across every project URL in the portal.
# https://app.asana.com/1/1213645083721316/…
ASANA_WORKSPACE_GID=1213645083721316

# Asana projects (one project GID per board):
#   0. Master Inbox — "00 · Master Inbox" (MLRO triage queue; all submissions land here first)
ASANA_PROJECT_GID=1214148630166524
#   1. STR / SAR filings
ASANA_SAR_PROJECT_GID=1214148631336502
#   2. Transaction monitor alerts
ASANA_TM_PROJECT_GID=1214148661083263
#   3. Auto-escalations (score-delta ≥ 15 between runs)
ASANA_ESCALATIONS_PROJECT_GID=1214148643568798

# Asana primary assignee — Luisa Fernanda (MLRO). Every task created by the
# app is assigned to this GID so she receives Asana inbox notifications.
ASANA_ASSIGNEE_GID=1213645083721304

# Asana custom field GIDs for structured screening metadata on each task.
# The Asana API requires numeric GID keys — human-readable names are ignored.
# Obtain via: GET https://app.asana.com/api/1.0/custom_fields?workspace=<GID>
# Leave blank to skip custom fields (the task will still be created).
ASANA_CF_SUBJECT_GID=
ASANA_CF_ENTITY_TYPE_GID=
ASANA_CF_MODE_GID=
ASANA_CF_TOTAL_MATCHES_GID=

# Bearer token protecting /api/ongoing/run and /api/transaction-monitor/run
# from public invocation. Any high-entropy string — a UUID is fine.
# REQUIRED: if unset, these endpoints return 503 (fail-closed).
ONGOING_RUN_TOKEN=

# Bearer token protecting the /api/sanctions/watch scheduled ingestion endpoint.
# Same pattern as ONGOING_RUN_TOKEN — generate with: openssl rand -hex 32
# REQUIRED: if unset, sanctions list ingestion returns 503 (fail-closed).
SANCTIONS_CRON_TOKEN=

# Bearer token protecting admin endpoints: /api/keys (issue/list API keys),
# /api/keys/[id] (revoke/delete), /api/gdpr/export, /api/gdpr/delete.
# The portal UI receives this token via Next.js edge middleware (web/middleware.ts)
# so it is never exposed in the browser bundle. Generate with: openssl rand -hex 32
# REQUIRED: if unset, these endpoints return 503 (fail-closed).
ADMIN_TOKEN=

# Initial password for the l.fernanda (MLRO / CO) portal account.
# If unset, a random password is generated at first runtime request and printed
# to server logs. Set this in Netlify env vars so the password survives redeploys.
# Min 8 characters. Change via /access-control after first login.
# RECOMMENDED: set before first deploy to avoid password rotation surprises.
LUISA_INITIAL_PASSWORD=

# HMAC-SHA256 session signing secret used by web/middleware.ts and
# web/lib/server/auth.ts. All browser sessions are HMAC-signed with this
# key. If unset in production, the middleware rejects ALL sessions (fail-closed).
# Generate with: openssl rand -hex 32
# REQUIRED: if unset, all portal page requests redirect to /login in a loop.
SESSION_SECRET=

# REQUIRED: used by lib/server/tenant.ts for JWT signing/verification.
# Generate with: openssl rand -base64 32
JWT_SIGNING_SECRET=

# HMAC-SHA256 secret for the tamper-evident server-side audit chain
# (/api/audit/sign, /api/audit/verify). Every MLRO disposition, STR, and
# freeze is sealed into an append-only chain in Netlify Blobs — required
# for FDL 10/2025 Art.24 10-year retention compliance.
# Generate with: openssl rand -hex 64
# REQUIRED: if unset, /api/audit/sign returns 503 (fail-closed).
AUDIT_CHAIN_SECRET=

# Public base URL of this deployment. Used to construct webhook callback URLs
# in /api/ongoing/run delta-alert payloads. Falls back to http://localhost:3000
# in development — MUST be set correctly in production.
NEXT_PUBLIC_APP_URL=

# ─────────────────────────────────────────────────────────────────────────
# REQUIRED — goAML FIU reporting identity
# Used by /api/goaml and /api/sar-report when submitting STRs to the UAE FIU.
#
# Multi-entity setup (preferred): set HAWKEYE_ENTITIES below to a JSON
# array of every legal entity the operator files STRs for. The MLRO
# identity (name / email / phone) is shared across every entity in the
# group — set it once in GOAML_MLRO_* below.
#
# Single-entity legacy setup: leave HAWKEYE_ENTITIES unset and only fill
# the single GOAML_RENTITY_ID / GOAML_RENTITY_BRANCH vars. The code
# transparently falls back so existing deployments keep working.
# ─────────────────────────────────────────────────────────────────────────

# Multi-entity reporting entities — JSON array. One line, no comments.
# Each object: { id, name, goamlRentityId, goamlBranch?, jurisdiction? }
# - id: stable slug used by the STR/SAR form dropdown and audit chain.
# - name: human-readable entity name shown in the dropdown.
# - goamlRentityId: assigned by UAE FIU on registration. Use "REPLACE_ME"
#   as a placeholder until that ID lands.
# - goamlBranch: optional branch code if the entity has multiple branches.
# - jurisdiction: ISO-3166-1 alpha-2; defaults to "AE" (UAE).
# Example with 7 UAE entities (replace names + REPLACE_ME values):
HAWKEYE_ENTITIES=[{"id":"entity-01","name":"Entity 01","goamlRentityId":"REPLACE_ME"},{"id":"entity-02","name":"Entity 02","goamlRentityId":"REPLACE_ME"},{"id":"entity-03","name":"Entity 03","goamlRentityId":"REPLACE_ME"},{"id":"entity-04","name":"Entity 04","goamlRentityId":"REPLACE_ME"},{"id":"entity-05","name":"Entity 05","goamlRentityId":"REPLACE_ME"},{"id":"entity-06","name":"Entity 06","goamlRentityId":"REPLACE_ME"},{"id":"entity-07","name":"Entity 07","goamlRentityId":"REPLACE_ME"}]

# Default entity preselected on the STR/SAR form. Must match an `id`
# from HAWKEYE_ENTITIES. When unset, the first entity in the array wins.
HAWKEYE_DEFAULT_ENTITY_ID=entity-01

# Single-entity legacy fallback — only used when HAWKEYE_ENTITIES is unset.
# Reporting entity ID assigned by the UAE FIU after registration.
# Defaults to "PENDING_FIU_ASSIGNMENT" — MUST be replaced before live STR filing.
GOAML_RENTITY_ID=

# Optional branch code if the reporting entity has multiple branches registered.
GOAML_RENTITY_BRANCH=

# MLRO identity embedded in every goAML XML submission. Shared across
# every entity in HAWKEYE_ENTITIES — the MLRO is a single person.
GOAML_MLRO_FULL_NAME=
GOAML_MLRO_EMAIL=
GOAML_MLRO_PHONE=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — outbound webhooks (customer-facing delta alerts)
# ─────────────────────────────────────────────────────────────────────────

HAWKEYE_WEBHOOK_URL=
HAWKEYE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — sanctions-list ingestion (Phase 2+)
# Leave blank to use the bundled seed corpus only.
# ─────────────────────────────────────────────────────────────────────────

UN_CONSOLIDATED_URL=https://scsanctions.un.org/resources/xml/en/consolidated.xml
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
OFAC_CONS_URL=https://www.treasury.gov/ofac/downloads/consolidated/cons_prim.xml
EU_FSF_URL=https://webgate.ec.europa.eu/fsd/fsf/public/files/xmlFullSanctionsList_1_1/content
UK_OFSI_URL=https://ofsistorage.blob.core.windows.net/publishlive/2022format/ConList.xml
UAE_EOCN_URL=
OPENSANCTIONS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — adverse-media upgrades. Leave blank to stay on the free
# multi-locale Google News RSS path that already powers /api/news-search.
# ─────────────────────────────────────────────────────────────────────────

NEWSAPI_KEY=
GDELT_API_KEY=
GOOGLE_CSE_ID=
GOOGLE_CSE_KEY=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — Regulatory Q&A external RAG (luuisotorres/AML-MultiAgent-RAG)
# Base URL of a running AML-MultiAgent-RAG instance (4-agent pipeline:
# RAG + Confidence + Consistency + Orchestrator, GPT-4o + Qdrant).
# Powers the "Regulatory Q&A" tab on /mlro-advisor with source-cited
# answers and confidence/consistency quality gates.
# When unset (or unreachable), the tab transparently falls back to the
# MLRO Advisor pipeline using ANTHROPIC_API_KEY — no extra config needed.
# Example: COMPLIANCE_RAG_URL=https://aml-rag.your-host.com
# ─────────────────────────────────────────────────────────────────────────

COMPLIANCE_RAG_URL=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — Upstash Redis (strict-mode rate limiting)
# Without these, rate limiting falls back to Netlify Blobs fixed-window
# counters which are soft-enforced (no atomic CAS — see rate-limit.ts).
# Provision a Redis database at https://console.upstash.com and paste the
# REST URL + token below to get atomic INCR-based hard limits instead.
# ─────────────────────────────────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — cross-validation services (all fail-soft; leave blank to skip)
# ─────────────────────────────────────────────────────────────────────────

# moov-io/watchman — OFAC / global sanctions cross-validation HTTP API.
# Run locally: docker run -p 8084:8084 moov/watchman
# https://github.com/moov-io/watchman
WATCHMAN_URL=

# checkmarble/marble — real-time AML decision engine screening endpoint.
# Self-hosted or SaaS; see https://github.com/checkmarble/marble
MARBLE_API_URL=
MARBLE_API_KEY=

# jube-home/aml-fraud-transaction-monitoring — ML-based AML risk scoring.
# Run locally via docker compose in the jube repo.
# https://github.com/jube-home/aml-fraud-transaction-monitoring
JUBE_API_URL=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — brain-reason local sidecar (server/brain-reason.mjs).
# Only relevant for on-prem / air-gapped deployments.
# ─────────────────────────────────────────────────────────────────────────

PORT=8081
EXECUTOR_MODEL=claude-sonnet-4-6
ADVISOR_MODEL=claude-opus-4-7
MAX_BODY_BYTES=262144
RATE_WINDOW_MS=60000
RATE_MAX=30
AUDIT_DIR=

# ═════════════════════════════════════════════════════════════════════════
# INTELLIGENCE VENDOR ADAPTERS  (231-source surface — see web/lib/intelligence/)
# ═════════════════════════════════════════════════════════════════════════
# Every adapter below is env-key gated. Absent keys → adapter sleeps as
# NULL and contributes nothing. Setting any key wakes that vendor up
# automatically — no code change needed.
#
# Tiers:
#   T1  free keys (just sign up)        — RECOMMENDED ALL
#   T2  free toggles (no key, set =1)   — RECOMMENDED ALL
#   T3  commercial (paid)               — pick what regulator demands
#
# After editing on Netlify: trigger a redeploy for changes to take effect.

# ─────────────────────────────────────────────────────────────────────────
# T1 — FREE NEWS / ADVERSE-MEDIA (sign up, no payment)
# ─────────────────────────────────────────────────────────────────────────

