# Layer-1 registry snapshots — generated by `npm run registry:ingest`,
# may contain controlling regulatory text and internal entity doctrine
# that should not be committed alongside the engine code.
data/registry/
# Layer-7 KPI snapshots — generated nightly by the regression harness;
# may contain operator queries that are out of scope for the public
# repo. Commit only the harness code, not the rolling output.
data/eval/kpi-snapshot.json
# Operator-enriched seed files may contain non-public FIU entity data
# (real goAML entity IDs, internal watchlist additions). The public
# regulatory seeds (EOCN, LTL) already in git are safe; any operator
# additions should use the Netlify Blobs ingest pipeline, not committed JSON.
data/seeds/operator-*.json
data/seeds/private-*.json
data/seeds/*-internal.json
