{
  "name": "hawkeye-sterling-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "gen:next-env": "printf '/// <reference types=\"next\" />\\n/// <reference types=\"next/image-types/global\" />\\n' > next-env.d.ts",
    "typecheck": "npm run gen:next-env && tsc --noEmit",
    "test:reports": "tsx scripts/test-compliance-report.ts",
    "check:pii-guard": "bash -c 'if grep -rn \"new Anthropic\" app --include=\"*.ts\" --include=\"*.tsx\" 2>/dev/null | grep -v \"//\"; then echo \"PII GUARD BYPASS DETECTED: use getAnthropicClient() from @/lib/server/llm\" && exit 1; fi'",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@e965/xlsx": "^0.20.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@netlify/blobs": "^10.7.4",
    "@netlify/functions": "^5.2.0",
    "@types/swagger-ui-react": "^5.18.0",
    "@upstash/box": "^0.4.3",
    "@upstash/redis": "^1.34.8",
    "fastest-levenshtein": "^1.0.16",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "next": "15.5.18",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-is": "19.2.6",
    "styled-jsx": "5.1.6",
    "swagger-ui-react": "^5.32.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "5.15.11",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "20.14.10",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.10",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3"
  },
  "overrides": {
    "react-copy-to-clipboard": "5.1.1",
    "qs": ">=6.15.2",
    "tmp": ">=0.2.6"
