{
  "openapi": "3.0.3",
  "info": {
    "title": "Hawkeye Sterling API",
    "version": "0.2.0",
    "description": "Regulator-grade AML/CFT/sanctions/PEP/adverse-media screening engine. Stateless, explainable, audit-chained.",
    "contact": {
      "name": "Hawkeye Sterling support",
      "url": "https://hawkeye-sterling.netlify.app/status"
    },
    "license": { "name": "Proprietary" }
  },
  "servers": [
    { "url": "https://hawkeye-sterling.netlify.app", "description": "Production" }
  ],
  "security": [{ "bearerAuth": [] }],
  "paths": {

    "/api/quick-screen": {
      "post": {
        "summary": "Run a quick-screen against the sanctions corpus",
        "tags": ["Screening"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/QuickScreenRequest" },
              "example": {
                "subject": {
                  "name": "Zeynep Basak Halac",
                  "aliases": ["Z. Halac", "Zeynep Halac"],
                  "entityType": "individual",
                  "jurisdiction": "TR"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Match ensemble result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuickScreenResult" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },

    "/api/super-brain": {
      "post": {
        "summary": "Full cognitive fusion: PEP + jurisdiction + ESG + typologies + redlines",
        "tags": ["Screening"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subject"],
                "properties": {
                  "subject": { "$ref": "#/components/schemas/Subject" },
                  "roleText": {
                    "type": "string",
                    "description": "PEP role description — e.g. Minister of Finance, Director"
                  },
                  "adverseMediaText": {
                    "type": "string",
                    "description": "Paste any news / adverse media narrative here for classification"
                  }
                }
              },
              "example": {
                "subject": {
                  "name": "Zeynep Basak Halac",
                  "aliases": ["Z. Halac"],
                  "entityType": "individual",
                  "jurisdiction": "TR"
                },
                "roleText": "Director, gold refinery, Ankara",
                "adverseMediaText": "Arrested in connection with gold smuggling and money laundering operation, Ankara 2024"
              }
            }
          }
        },
        "responses": { "200": { "description": "Fused brain output — composite score, PEP, ESG, typologies, redlines, jurisdiction" } }
      }
    },

    "/api/batch-screen": {
      "post": {
        "summary": "Bulk screening (up to 500 rows / call)",
        "tags": ["Screening"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BatchScreenRequest" },
              "example": {
                "rows": [
                  {
                    "name": "Zeynep Basak Halac",
                    "aliases": ["Z. Halac"],
                    "entityType": "individual",
                    "jurisdiction": "TR"
                  },
                  {
                    "name": "Acme Gold Trading LLC",
                    "entityType": "organisation",
                    "jurisdiction": "AE"
                  },
                  {
                    "name": "Viktor Petrov",
                    "entityType": "individual",
                    "jurisdiction": "RU",
                    "dob": "1975-03-15"
                  }
                ]
              }
            }
          }
        },
        "responses": { "200": { "description": "Per-row screening results with severity + list coverage" } }
      }
    },

    "/api/news-search": {
      "get": {
        "summary": "Multi-lingual adverse-media dossier (8 locales: EN, ES, FR, RU, ZH, AR, PT, TR)",
        "tags": ["Adverse Media"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Subject name to search for across all news locales",
            "schema": { "type": "string", "maxLength": 500 },
            "example": "Zeynep Basak Halac"
          }
        ],
        "responses": {
          "200": { "description": "Clustered article dossier with severity, keyword groups and ESG categories" }
        }
      }
    },

    "/api/ongoing": {
      "get": {
        "summary": "List all subjects enrolled in ongoing monitoring",
        "tags": ["Monitoring"],
        "responses": { "200": { "description": "Array of enrolled subjects" } }
      },
      "post": {
        "summary": "Enrol a subject in ongoing monitoring",
        "tags": ["Monitoring"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Your internal subject ID — alphanumeric, ._-: only, max 128 chars",
                    "example": "HS-10001"
                  },
                  "name": { "type": "string", "example": "Zeynep Basak Halac" },
                  "aliases": { "type": "array", "items": { "type": "string" }, "example": ["Z. Halac"] },
                  "entityType": {
                    "type": "string",
                    "enum": ["individual", "organisation", "vessel", "aircraft", "other"],
                    "example": "individual"
                  },
                  "jurisdiction": { "type": "string", "example": "TR" },
                  "group": { "type": "string", "description": "Business group or unit", "example": "Corporate Banking" },
                  "caseId": { "type": "string", "description": "Linked case reference", "example": "CAS-10001" },
                  "cadence": {
                    "type": "string",
                    "enum": ["hourly", "thrice_daily", "daily", "weekly", "monthly"],
                    "default": "thrice_daily",
                    "example": "daily"
                  }
                }
              },
              "example": {
                "id": "HS-10001",
                "name": "Zeynep Basak Halac",
                "aliases": ["Z. Halac"],
                "entityType": "individual",
                "jurisdiction": "TR",
                "caseId": "CAS-10001",
                "cadence": "daily"
              }
            }
          }
        },
        "responses": { "200": { "description": "Enrolment confirmed with schedule seeded" } }
      },
      "delete": {
        "summary": "Remove a subject from ongoing monitoring",
        "tags": ["Monitoring"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "Subject ID to remove",
            "schema": { "type": "string" },
            "example": "HS-10001"
          }
        ],
        "responses": { "200": { "description": "Subject removed from monitoring" } }
      }
    },

    "/api/schedule": {
      "get": {
        "summary": "List all per-subject rescreening schedules",
        "tags": ["Monitoring"],
        "responses": { "200": { "description": "Array of active schedules" } }
      },
      "post": {
        "summary": "Create or update a per-subject rescreening schedule",
        "tags": ["Monitoring"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "subjectId": { "type": "string", "description": "Must match an enrolled subject ID", "example": "HS-10001" },
                  "cadence": {
                    "type": "string",
                    "enum": ["hourly", "daily", "weekly", "monthly"],
                    "example": "weekly"
                  },
                  "scoreThreshold": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Only re-run if composite score exceeds this value",
                    "example": 0.6
                  }
                }
              },
              "example": {
                "subjectId": "HS-10001",
                "cadence": "weekly",
                "scoreThreshold": 0.6
              }
            }
          }
        },
        "responses": { "200": { "description": "Schedule persisted — nextRunAt returned" } }
      },
      "delete": {
        "summary": "Delete a rescreening schedule",
        "tags": ["Monitoring"],
        "parameters": [
          {
            "name": "subjectId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "HS-10001"
          }
        ],
        "responses": { "200": { "description": "Schedule deleted" } }
      }
    },

    "/api/feedback": {
      "get": {
        "summary": "Retrieve aggregated FP / TM statistics",
        "tags": ["Learning"],
        "responses": { "200": { "description": "Aggregated false-positive and true-match stats" } }
      },
      "post": {
        "summary": "Submit an analyst verdict (false positive, true match, needs review)",
        "tags": ["Learning"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subjectId", "listId", "listRef", "candidateName", "verdict", "analyst"],
                "properties": {
                  "subjectId": { "type": "string", "example": "HS-10001" },
                  "listId": {
                    "type": "string",
                    "description": "Sanctions list identifier",
                    "example": "OFAC-SDN"
                  },
                  "listRef": {
                    "type": "string",
                    "description": "Reference number on the list",
                    "example": "SDN-12345"
                  },
                  "candidateName": {
                    "type": "string",
                    "description": "Name as it appears on the sanctions list",
                    "example": "HALAC ZEYNEP BASAK"
                  },
                  "verdict": {
                    "type": "string",
                    "enum": ["false_positive", "true_match", "needs_review"],
                    "example": "false_positive"
                  },
                  "analyst": { "type": "string", "example": "Luisa Fernandez" },
                  "reason": {
                    "type": "string",
                    "description": "Explanation for the verdict",
                    "example": "DOB mismatch — different individual, confirmed via passport"
                  }
                }
              },
              "example": {
                "subjectId": "HS-10001",
                "listId": "OFAC-SDN",
                "listRef": "SDN-12345",
                "candidateName": "HALAC ZEYNEP BASAK",
                "verdict": "false_positive",
                "analyst": "Luisa Fernandez",
                "reason": "DOB mismatch — different individual, confirmed via passport"
              }
            }
          }
        },
        "responses": { "200": { "description": "Verdict recorded — FP rate recalibrated" } }
      }
    },

    "/api/corrections": {
      "get": {
        "summary": "List data-subject correction requests",
        "tags": ["Records"],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Filter by status",
            "schema": {
              "type": "string",
              "enum": ["received", "under_review", "correction_applied", "record_retained", "escalated"]
            }
          }
        ],
        "responses": { "200": { "description": "Array of correction requests" } }
      },
      "post": {
        "summary": "File a new data-subject correction request",
        "tags": ["Records"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subjectName", "requesterEmail", "claim"],
                "properties": {
                  "subjectName": { "type": "string", "example": "Zeynep Basak Halac" },
                  "requesterEmail": { "type": "string", "format": "email", "example": "legal@counsel.com" },
                  "requesterName": { "type": "string", "example": "John Smith" },
                  "requesterCapacity": {
                    "type": "string",
                    "enum": ["subject", "legal_representative", "data_controller", "other"],
                    "default": "subject",
                    "example": "legal_representative"
                  },
                  "claim": {
                    "type": "string",
                    "description": "Description of the correction being requested",
                    "example": "Subject incorrectly matched to OFAC SDN entry — confirmed different individual with different nationality and DOB"
                  },
                  "listId": { "type": "string", "example": "OFAC-SDN" },
                  "listRef": { "type": "string", "example": "SDN-12345" },
                  "evidenceUrls": {
                    "type": "array",
                    "items": { "type": "string", "format": "uri" },
                    "example": ["https://example.com/passport-copy.pdf"]
                  }
                }
              },
              "example": {
                "subjectName": "Zeynep Basak Halac",
                "requesterEmail": "legal@counsel.com",
                "requesterName": "John Smith",
                "requesterCapacity": "legal_representative",
                "claim": "Subject incorrectly matched to OFAC SDN entry — confirmed different individual with different nationality and DOB",
                "listId": "OFAC-SDN",
                "listRef": "SDN-12345",
                "evidenceUrls": ["https://example.com/passport-copy.pdf"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Correction request received — 30-day SLA clock started" } }
      }
    },

    "/api/gdpr/export": {
      "post": {
        "summary": "GDPR Art. 15 — right-of-access export",
        "tags": ["Compliance"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Provide subjectId OR email — at least one required",
                "properties": {
                  "subjectId": { "type": "string", "example": "HS-10001" },
                  "email": { "type": "string", "format": "email", "example": "subject@example.com" }
                }
              },
              "example": {
                "subjectId": "HS-10001"
              }
            }
          }
        },
        "responses": { "200": { "description": "Full data export package" } }
      }
    },

    "/api/gdpr/delete": {
      "post": {
        "summary": "GDPR Art. 17 — right-to-erasure",
        "tags": ["Compliance"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Provide subjectId OR email — at least one required",
                "properties": {
                  "subjectId": { "type": "string", "example": "HS-10001" },
                  "email": { "type": "string", "format": "email", "example": "subject@example.com" },
                  "dryRun": {
                    "type": "boolean",
                    "default": false,
                    "description": "true = preview what will be deleted without executing",
                    "example": true
                  }
                }
              },
              "example": {
                "subjectId": "HS-10001",
                "dryRun": true
              }
            }
          }
        },
        "responses": { "200": { "description": "Erasure receipt — FDL 10/2025 Art.24 audit trail retained" } }
      }
    },

    "/api/keys": {
      "get": {
        "summary": "List all API keys (Admin only)",
        "tags": ["Auth"],
        "responses": { "200": { "description": "Array of issued API keys (plaintext never returned)" } }
      },
      "post": {
        "summary": "Issue a new API key (Admin only)",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email"],
                "properties": {
                  "name": { "type": "string", "description": "Name of person or application", "example": "Luisa Fernandez" },
                  "email": { "type": "string", "format": "email", "example": "luisa@company.com" },
                  "tier": {
                    "type": "string",
                    "enum": ["free", "professional", "enterprise"],
                    "default": "free",
                    "example": "professional"
                  }
                }
              },
              "example": {
                "name": "Luisa Fernandez",
                "email": "luisa@company.com",
                "tier": "professional"
              }
            }
          }
        },
        "responses": { "200": { "description": "New API key — plaintext returned once, store securely" } }
      }
    },

    "/api/keys/{id}": {
      "post": {
        "summary": "Revoke an API key (Admin only)",
        "tags": ["Auth"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "API key ID to revoke",
            "schema": { "type": "string" },
            "example": "key_abc123"
          }
        ],
        "responses": { "200": { "description": "Key revoked — soft disable, not deleted" } }
      },
      "delete": {
        "summary": "Permanently delete an API key (Admin only)",
        "tags": ["Auth"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "API key ID to permanently delete",
            "schema": { "type": "string" },
            "example": "key_abc123"
          }
        ],
        "responses": { "200": { "description": "Key permanently deleted" } }
      }
    },

    "/api/tiers": {
      "get": {
        "summary": "List commercial tiers + limits",
        "tags": ["Auth"],
        "security": [],
        "responses": { "200": { "description": "All tier definitions with rate limits and monthly quotas" } }
      }
    },

    "/api/analytics": {
      "get": {
        "summary": "Operational analytics + 30 DPMS KPIs",
        "tags": ["Analytics"],
        "responses": { "200": { "description": "Analytics payload with 30 DPMS KPIs" } }
      }
    },

    "/api/status": {
      "get": {
        "summary": "Live health status of all services",
        "tags": ["System"],
        "security": [],
        "responses": { "200": { "description": "Service health, brain-soul status, and cognitive grade" } }
      }
    },
    "/api/gleif": {
      "post": {
        "summary": "GLEIF LEI lookup — entity record and ownership chain (KYB enrichment)",
        "tags": ["Enrichment"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Either { lei } for direct lookup or { query } for name search",
                "properties": {
                  "lei": { "type": "string", "description": "20-character LEI for direct lookup" },
                  "maxDepth": { "type": "integer", "default": 3, "description": "Ownership chain traversal depth" },
                  "query": { "type": "string", "description": "Entity name (search mode)" },
                  "limit": { "type": "integer", "default": 20, "description": "Max results in search mode" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "LEI record / ownership chain, or search results" },
          "400": { "$ref": "#/components/responses/Error" },
          "502": { "description": "Upstream GLEIF error" },
          "503": { "description": "GLEIF integration not configured" }
        }
      }
    },
    "/api/crypto-risk": {
      "post": {
        "summary": "Wallet AML risk scoring — taint analysis for ETH / BTC / TRX (VASP screening)",
        "tags": ["Screening"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["address"],
                "properties": {
                  "address": { "type": "string", "description": "Wallet address" },
                  "chain": { "type": "string", "enum": ["ethereum", "bitcoin", "tron"], "description": "Defaults to inferred chain" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Wallet risk score + taint exposure breakdown" },
          "400": { "$ref": "#/components/responses/Error" },
          "502": { "description": "Upstream provider error" },
          "503": { "description": "Crypto-risk provider not configured" }
        }
      }
    },
    "/api/vessel-check": {
      "post": {
        "summary": "IMO vessel sanctions screening — ownership, flag state, and list hits",
        "tags": ["Screening"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Single mode { imoNumber } or batch mode { imoNumbers } (max 50)",
                "properties": {
                  "imoNumber": { "type": "string", "description": "7-digit IMO number" },
                  "imoNumbers": { "type": "array", "items": { "type": "string" }, "maxItems": 50, "description": "Batch of IMO numbers (≤ 50)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Vessel record(s) with sanction-list hits and ownership chain" },
          "400": { "$ref": "#/components/responses/Error" },
          "503": { "description": "Vessel-check provider not configured" }
        }
      }
    },
    "/api/benford": {
      "post": {
        "summary": "Benford's Law forensic accounting — MAD, chi-squared, p-value, risk tier",
        "tags": ["Forensics"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amounts"],
                "properties": {
                  "amounts": { "type": "array", "items": { "type": "number" }, "description": "Transaction amounts to test" },
                  "label": { "type": "string", "description": "Optional label echoed in the result" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Per-digit breakdown, MAD, chi-squared, p-value, and risk tier" },
          "400": { "$ref": "#/components/responses/Error" },
          "422": { "description": "Insufficient data — fewer samples than required for a stable test" }
        }
      }
    },

    "/api/screening/run": {
      "post": {
        "summary": "Full AML/sanctions/PEP screening against all configured lists",
        "description": "Runs the complete Hawkeye screening pipeline: name matching across OFAC SDN, UN Consolidated, UAE EOCN, UAE LTL, and PEP lists, plus adverse media, adverse-AI, and redlines. Writes a tamper-evident audit chain entry on completion. Rate-limited per tier (UAE FDL 20/2018 Art.18).",
        "tags": ["Screening"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subject"],
                "properties": {
                  "subject": { "$ref": "#/components/schemas/Subject" },
                  "candidates": {
                    "type": "array",
                    "items": { "type": "object" },
                    "description": "Optional pre-fetched candidate list; if omitted the engine queries all lists"
                  },
                  "options": {
                    "type": "object",
                    "properties": {
                      "includeAdverseMedia": { "type": "boolean" },
                      "pepTier": { "type": "integer", "minimum": 1, "maximum": 3 }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Screening result with hits, score, severity, and audit ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "id": { "type": "string" },
                    "subject": { "$ref": "#/components/schemas/Subject" },
                    "hits": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "listId": { "type": "string" },
                          "listRef": { "type": "string" },
                          "matchRationale": { "type": "string" },
                          "score": { "type": "number" },
                          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] }
                        }
                      }
                    },
                    "score": { "type": "number", "description": "Composite risk score 0–100" },
                    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "none"] },
                    "generatedAt": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },

    "/api/sar-report": {
      "post": {
        "summary": "Generate a Suspicious Activity Report (SAR / STR) document",
        "description": "Generates a regulator-grade SAR/STR/CTR document after verifying four-eyes dual-attestation (UAE FDL 10/2025 Art.16). The report is tamper-evidently signed and appended to the audit chain. Supported filing types: STR, SAR, CTR, DPMSR, FFR, PNMR, HRCR, AIF, PEPR, FTFR.",
        "tags": ["Compliance"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["filingType", "caseId"],
                "properties": {
                  "filingType": {
                    "type": "string",
                    "enum": ["STR", "SAR", "CTR", "DPMSR", "FFR", "PNMR", "HRCR", "AIF", "PEPR", "FTFR"],
                    "description": "UAE FIU / FinCEN report type"
                  },
                  "caseId": { "type": "string", "description": "Case identifier — four-eyes approval must be recorded against this ID" },
                  "subjectId": { "type": "string" },
                  "narrative": { "type": "string", "description": "Operator-supplied SAR narrative" },
                  "amountAed": { "type": "number", "description": "Suspicious transaction amount in AED" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "HTML report document ready for download / regulatory submission",
            "content": { "text/html": { "schema": { "type": "string" } } }
          },
          "403": { "description": "Four-eyes gate not satisfied — two distinct approvers required (UAE FDL 10/2025 Art.16)" },
          "401": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },

    "/api/goaml": {
      "post": {
        "summary": "Generate a goAML XML envelope for UAE FIU filing",
        "description": "Serialises a goAML-compliant XML envelope for direct upload to the UAE FIU goAML portal. Supported report codes: STR, SAR, FFR, PNMR, CTR, AIF, EFT, HRC, RFI. Enforces four-eyes dual-attestation and writes to the tamper-evident audit chain.",
        "tags": ["Compliance"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reportCode", "subject", "narrative"],
                "properties": {
                  "reportCode": {
                    "type": "string",
                    "enum": ["STR", "SAR", "FFR", "PNMR", "CTR", "AIF", "EFT", "HRC", "RFI"],
                    "description": "goAML report type code"
                  },
                  "subject": {
                    "type": "object",
                    "required": ["name", "entityType"],
                    "properties": {
                      "name": { "type": "string" },
                      "entityType": { "type": "string", "enum": ["individual", "organisation", "vessel", "aircraft", "other"] },
                      "jurisdiction": { "type": "string" },
                      "dob": { "type": "string", "format": "date" },
                      "aliases": { "type": "array", "items": { "type": "string" } },
                      "idNumber": { "type": "string" },
                      "caseId": { "type": "string" }
                    }
                  },
                  "narrative": { "type": "string", "description": "Narrative description of the suspicious activity" },
                  "amountAed": { "type": "number" },
                  "currency": { "type": "string", "default": "AED" },
                  "counterparty": { "type": "string" },
                  "reportingEntity": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "goAML XML envelope",
            "content": { "application/xml": { "schema": { "type": "string", "format": "binary" } } }
          },
          "403": { "description": "Four-eyes gate not satisfied" },
          "401": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },

    "/api/four-eyes": {
      "get": {
        "summary": "List pending four-eyes approval items",
        "description": "Returns all pending dual-attestation items. Two distinct operators must approve before a regulated action (STR filing, freeze, EDD uplift, escalation) can proceed (UAE FDL 10/2025 Art.16, FATF R.26).",
        "tags": ["Compliance"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of four-eyes items with approval state",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string" },
                          "action": { "type": "string", "enum": ["str", "freeze", "decline", "edd-uplift", "escalate"] },
                          "status": { "type": "string", "enum": ["pending", "approved", "rejected", "expired"] },
                          "subjectId": { "type": "string" },
                          "caseId": { "type": "string" },
                          "initiatedAt": { "type": "string", "format": "date-time" },
                          "approverCount": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      },
      "post": {
        "summary": "Enqueue a new four-eyes approval request",
        "tags": ["Compliance"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action", "subjectId", "caseId"],
                "properties": {
                  "action": { "type": "string", "enum": ["str", "freeze", "decline", "edd-uplift", "escalate"] },
                  "subjectId": { "type": "string" },
                  "caseId": { "type": "string" },
                  "filingBlocked": { "type": "boolean", "description": "Set true to block filing until approved" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Four-eyes item created; pending second approval" },
          "401": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      },
      "patch": {
        "summary": "Record an approval or rejection",
        "description": "The actor identity is resolved from the inbound auth context. A single operator approving twice is rejected (collusion guard).",
        "tags": ["Compliance"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "decision", "rationale"],
                "properties": {
                  "id": { "type": "string", "description": "Four-eyes item ID" },
                  "decision": { "type": "string", "enum": ["approve", "reject"] },
                  "rationale": { "type": "string", "minLength": 20, "description": "Substantive reasoning (min 20 chars, UAE FDL 10/2025 Art.16)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Approval recorded; returns updated status" },
          "409": { "description": "Same actor already approved — collusion guard triggered" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },

    "/api/audit-trail": {
      "get": {
        "summary": "Read the tamper-evident audit chain",
        "description": "Returns paginated entries from the SHA-256 / HMAC-SHA256 audit chain stored in Netlify Blobs. Set verified=true to run full cryptographic chain verification on retrieval (slower but provides integrity guarantees for regulatory review). FDL 10/2025 Art.24 audit trail retention.",
        "tags": ["Compliance"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "default": 50, "maximum": 200 } },
          { "name": "verified", "in": "query", "schema": { "type": "boolean", "default": false }, "description": "Run HMAC verification on each entry before returning" },
          { "name": "tenantId", "in": "query", "schema": { "type": "string", "default": "default" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated audit entries with optional tamper marker",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "totalEntries": { "type": "integer" },
                    "page": { "type": "integer" },
                    "pageSize": { "type": "integer" },
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "seq": { "type": "integer" },
                          "entryHash": { "type": "string" },
                          "prevHash": { "type": "string" },
                          "hashAlg": { "type": "string", "enum": ["sha256", "hmac-sha256", "fnv1a"] },
                          "payload": { "type": "object" },
                          "at": { "type": "string", "format": "date-time" }
                        }
                      }
                    },
                    "tamperMarker": {
                      "type": "object",
                      "description": "Present if tampering is detected",
                      "properties": {
                        "detectedAt": { "type": "string", "format": "date-time" },
                        "tamperedAt": { "type": "array", "items": { "type": "integer" } }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    }

  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "ADMIN_TOKEN or API key (hks_live_…)"
      }
    },
    "schemas": {
      "Subject": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "Zeynep Basak Halac" },
          "aliases": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["Z. Halac"]
          },
          "entityType": {
            "type": "string",
            "enum": ["individual", "organisation", "vessel", "aircraft", "other"],
            "example": "individual"
          },
          "jurisdiction": { "type": "string", "example": "TR" }
        }
      },
      "QuickScreenRequest": {
        "type": "object",
        "required": ["subject"],
        "properties": {
          "subject": { "$ref": "#/components/schemas/Subject" },
          "candidates": {
            "type": "array",
            "items": { "type": "object" },
            "description": "Custom watchlist to screen against. Omit to use live OFAC/UN/EU/UK/UAE corpus (max 5,000 entries)"
          },
          "options": { "type": "object" }
        }
      },
      "QuickScreenResult": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "topScore": { "type": "number" },
          "severity": { "type": "string", "enum": ["clear", "low", "medium", "high", "critical"] },
          "listsChecked": { "type": "integer" },
          "candidatesChecked": { "type": "integer" },
          "durationMs": { "type": "integer" },
          "hits": { "type": "array", "items": { "type": "object" } }
        }
      },
      "BatchScreenRequest": {
        "type": "object",
        "required": ["rows"],
        "properties": {
          "rows": {
            "type": "array",
            "maxItems": 500,
            "items": {
              "allOf": [
                { "$ref": "#/components/schemas/Subject" },
                {
                  "type": "object",
                  "properties": {
                    "dob": { "type": "string", "description": "Date of birth (ISO 8601)", "example": "1980-06-15" },
                    "gender": { "type": "string", "example": "F" },
                    "idNumber": { "type": "string", "description": "Passport or national ID number", "example": "A1234567" }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "responses": {
      "Error": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "ok": { "type": "boolean" },
                "error": { "type": "string" }
              }
            }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded",
        "headers": {
          "Retry-After": { "schema": { "type": "integer" } },
          "X-RateLimit-Remaining-Minute": { "schema": { "type": "integer" } }
        }
      }
    }
  }
}
