{
  "openapi": "3.0.3",
  "info": {
    "title": "Hawkeye Sterling API",
    "version": "0.2.0",
    "description": "Regulator-grade AML/CFT/sanctions/PEP/adverse-media screening engine. Stateless, explainable, audit-chained.",
    "contact": {
      "name": "Hawkeye Sterling support",
      "url": "https://hawkeye-sterling.netlify.app/status"
    },
    "license": { "name": "Proprietary" }
  },
  "servers": [
    { "url": "https://hawkeye-sterling.netlify.app", "description": "Production" }
  ],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/quick-screen": {
      "post": {
        "summary": "Run a quick-screen against the sanctions corpus",
        "tags": ["Screening"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/QuickScreenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Match ensemble result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuickScreenResult" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/super-brain": {
      "post": {
        "summary": "Full cognitive fusion: PEP + jurisdiction + ESG + typologies + redlines",
        "tags": ["Screening"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subject"],
                "properties": {
                  "subject": { "$ref": "#/components/schemas/Subject" },
                  "roleText": { "type": "string" },
                  "adverseMediaText": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Fused brain output" } }
      }
    },
    "/api/news-search": {
      "post": {
        "summary": "Multi-lingual adverse-media dossier (7 locales)",
        "tags": ["Adverse Media"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["q"],
                "properties": {
                  "q": { "type": "string", "description": "Subject name or search query" },
                  "locales": { "type": "array", "items": { "type": "string" }, "description": "ISO locale codes to search (default: all 7)" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Clustered article dossier" } }
      }
    },
    "/api/batch-screen": {
      "post": {
        "summary": "Bulk screening (up to 500 rows / call)",
        "tags": ["Screening"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BatchScreenRequest" }
            }
          }
        },
        "responses": { "200": { "description": "Per-row screening result" } }
      }
    },
    "/api/ongoing": {
      "post": {
        "summary": "List, enrol, or remove a subject from ongoing monitoring",
        "tags": ["Monitoring"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["list", "enrol", "remove"], "description": "Operation to perform" },
                  "subjectId": { "type": "string", "description": "Required for enrol / remove" },
                  "subject": { "$ref": "#/components/schemas/Subject", "description": "Required for enrol" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/schedule": {
      "post": {
        "summary": "List or create / update a per-subject rescreening schedule",
        "tags": ["Monitoring"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["list", "upsert"], "description": "list returns all schedules; upsert creates or updates" },
                  "subjectId": { "type": "string", "description": "Required for upsert" },
                  "cadence": { "type": "string", "enum": ["hourly", "daily", "weekly", "monthly"] },
                  "scoreThreshold": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Schedule persisted / list returned" } }
      }
    },
    "/api/feedback": {
      "post": {
        "summary": "Retrieve aggregated FP / TM statistics or submit an analyst verdict",
        "tags": ["Learning"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["stats", "submit"], "description": "stats returns aggregates; submit records a verdict" },
                  "caseId": { "type": "string" },
                  "verdict": { "type": "string", "enum": ["true_positive", "false_positive", "escalated"] },
                  "notes": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Stats payload or verdict receipt" } }
      }
    },
    "/api/corrections": {
      "post": {
        "summary": "List, file, fetch or update a data-subject correction request",
        "tags": ["Records"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["list", "file", "fetch", "update"], "description": "list = all requests; file = new (public); fetch = single; update = status / appeal" },
                  "id": { "type": "string", "description": "Required for fetch / update" },
                  "subjectName": { "type": "string" },
                  "details": { "type": "string" },
                  "status": { "type": "string", "enum": ["open", "in_review", "resolved", "rejected"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Correction record or receipt with 30-day SLA" } }
      }
    },
    "/api/gdpr/export": {
      "post": {
        "summary": "GDPR Art. 15 — right-of-access export",
        "tags": ["Compliance"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subjectId"],
                "properties": {
                  "subjectId": { "type": "string" },
                  "format": { "type": "string", "enum": ["json", "pdf"], "default": "json" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Full data export package" } }
      }
    },
    "/api/gdpr/delete": {
      "post": {
        "summary": "GDPR Art. 17 — right-to-erasure",
        "tags": ["Compliance"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subjectId", "reason"],
                "properties": {
                  "subjectId": { "type": "string" },
                  "reason": { "type": "string" },
                  "retainAuditTrail": { "type": "boolean", "default": true, "description": "FDL 10/2025 Art.24 — audit trail retained even after erasure" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Erasure receipt with regulatory retention notice" } }
      }
    },
    "/api/keys": {
      "post": {
        "summary": "List API keys or issue a new API key",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["list", "issue"], "description": "list requires auth; issue is public (instant signup)" },
                  "label": { "type": "string", "description": "Human-readable label for the new key" },
                  "tier": { "type": "string", "enum": ["starter", "professional", "enterprise"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Key list or new plaintext key (returned once)" } }
      }
    },
    "/api/keys/{id}": {
      "post": {
        "summary": "Revoke or permanently delete an API key",
        "tags": ["Auth"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["revoke", "delete"], "description": "revoke = soft disable; delete = permanent" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/tiers": {
      "post": {
        "summary": "List commercial tiers + limits",
        "tags": ["Auth"],
        "security": [],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "currency": { "type": "string", "default": "USD", "description": "Return pricing in this currency" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Tier definitions and rate limits" } }
      }
    },
    "/api/analytics": {
      "post": {
        "summary": "Operational analytics + 30 DPMS KPIs",
        "tags": ["Analytics"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "from": { "type": "string", "format": "date", "description": "Start of reporting window (ISO date)" },
                  "to": { "type": "string", "format": "date", "description": "End of reporting window (ISO date)" },
                  "include": { "type": "array", "items": { "type": "string" }, "description": "KPI subset to return (default: all)" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Analytics payload with 30 DPMS KPIs" } }
      }
    },
    "/api/status": {
      "post": {
        "summary": "Live health status of all services",
        "tags": ["System"],
        "security": [],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "verbose": { "type": "boolean", "default": false, "description": "Include full brain-soul manifest in response" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Service health, brain-soul status, and cognitive grade" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API key (hks_live_…)"
      }
    },
    "schemas": {
      "Subject": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "entityType": { "type": "string", "enum": ["individual", "organisation", "vessel", "aircraft", "other"] },
          "jurisdiction": { "type": "string" }
        }
      },
      "QuickScreenRequest": {
        "type": "object",
        "required": ["subject", "candidates"],
        "properties": {
          "subject": { "$ref": "#/components/schemas/Subject" },
          "candidates": { "type": "array", "items": { "type": "object" } },
          "options": { "type": "object" }
        }
      },
      "QuickScreenResult": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "topScore": { "type": "number" },
          "severity": { "type": "string", "enum": ["clear", "low", "medium", "high", "critical"] },
          "listsChecked": { "type": "integer" },
          "candidatesChecked": { "type": "integer" },
          "durationMs": { "type": "integer" },
          "hits": { "type": "array", "items": { "type": "object" } }
        }
      },
      "BatchScreenRequest": {
        "type": "object",
        "required": ["rows"],
        "properties": {
          "rows": {
            "type": "array",
            "maxItems": 500,
            "items": { "$ref": "#/components/schemas/Subject" }
          },
          "options": { "type": "object" }
        }
      }
    },
    "responses": {
      "Error": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "ok": { "type": "boolean" },
                "error": { "type": "string" }
              }
            }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded",
        "headers": {
          "Retry-After": { "schema": { "type": "integer" } },
          "X-RateLimit-Remaining-Minute": { "schema": { "type": "integer" } }
        }
      }
    }
  }
}
