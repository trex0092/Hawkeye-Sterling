# EditorConfig — https://editorconfig.org
# Consistent whitespace across editors for the whole monorepo.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: trailing whitespace can be a hard line break — do not trim.
[*.md]
trim_trailing_whitespace = false

# Makefiles require real tabs.
[Makefile]
indent_style = tab

# Go, if ever added, uses tabs.
[*.go]
indent_style = tab

# YAML and JSON stay at 2-space.
[*.{yml,yaml,json}]
indent_size = 2

# Shell scripts.
[*.sh]
indent_size = 2
