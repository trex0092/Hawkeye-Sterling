# Treat the vendored Open Banking Tracker JSON files as binary so Git
# does not perform CRLF normalisation on the 11 MB providers.json. Line-
# ending churn on these files would otherwise dominate every diff.
web/lib/data/open-banking/*.json   binary

# UAE seed JSON files: keep LF on commit (Windows checkouts may have
# CRLF locally — Git won't store the conversion).
data/eocn_seed.json     text eol=lf
data/uae_ltl_seed.json  text eol=lf
